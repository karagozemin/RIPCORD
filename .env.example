# Data source: mock | http
RIPCORD_DATA_SOURCE=mock

# Optional: path to mock Pacifica state JSON
RIPCORD_MOCK_FILE=examples/pacifica_state.sample.json

# Pacifica HTTP settings (used when RIPCORD_DATA_SOURCE=http)
PACIFICA_BASE_URL=https://api.pacifica.example
PACIFICA_ACCOUNT_ID=your_account_id
PACIFICA_STATE_PATH=/account/state
PACIFICA_TIMEOUT_SECONDS=8
PACIFICA_API_KEY=
