# Data source: mock | http
RIPCORD_DATA_SOURCE=mock

# Optional: path to mock Pacifica state JSON
RIPCORD_MOCK_FILE=examples/pacifica_state.sample.json

# Pacifica HTTP settings (used when RIPCORD_DATA_SOURCE=http)
PACIFICA_BASE_URL=https://api.pacifica.example
PACIFICA_ACCOUNT_ID=your_account_id
PACIFICA_ACCOUNT_QUERY_KEY=account
PACIFICA_STATE_PATH=/account/state
PACIFICA_OPEN_ORDERS_PATH=/api/v1/orders
PACIFICA_TIMEOUT_SECONDS=8
PACIFICA_API_KEY=

# Execution integration prep (feature-flag)
RIPCORD_EXECUTION_ENABLED=false
PACIFICA_EXECUTION_ENDPOINT=
PACIFICA_AGENT_KEY=
RIPCORD_SIGNING_SECRET=

# Session/auth for web backend
RIPCORD_REQUIRE_SESSION=false
RIPCORD_SESSION_SECRET=change-me-in-production
RIPCORD_SESSION_TTL_SECONDS=43200
RIPCORD_STATE_DIR=.ripcord_state
